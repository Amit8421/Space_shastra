generator tenantClient {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GstType {
  NONE
  CGST_SGST
  IGST
}

model Client {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  gstin        String?
  stateCode    String?
  notes        String?
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  balance      Decimal       @default(0) @db.Decimal(14, 2)
  invoices     Invoice[]
  projects     Project[]
  quotations   Quotation[]
  transactions Transaction[]

  @@map("clients")
}

model Vendor {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  gstin          String?
  stateCode      String?
  category       String?
  notes          String?
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  balance        Decimal         @default(0) @db.Decimal(14, 2)
  purchases      Purchase[]
  transactions   Transaction[]
  vendorAccounts VendorAccount[]

  @@map("vendors")
}

model VendorAccount {
  id             String                       @id @default(cuid())
  vendorId       String
  projectId      String
  openingBalance Decimal                      @default(0) @db.Decimal(14, 2)
  currentBalance Decimal                      @default(0) @db.Decimal(14, 2)
  status         String                       @default("active")
  notes          String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  entries        VendorAccountEntry[]
  furnitureItems VendorAccountFurnitureItem[]
  project        Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor         Vendor                       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, projectId])
  @@index([projectId])
  @@map("vendor_accounts")
}

model VendorAccountEntry {
  id              String        @id @default(cuid())
  vendorAccountId String
  type            String
  amount          Decimal       @db.Decimal(14, 2)
  description     String
  date            DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)

  @@index([vendorAccountId])
  @@map("vendor_account_entries")
}

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String?
  clientId       String
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  startDate      DateTime?
  endDate        DateTime?
  status         String          @default("active")
  budget         Decimal?        @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoices       Invoice[]
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  purchases      Purchase[]
  quotations     Quotation[]
  transactions   Transaction[]
  vendorAccounts VendorAccount[]

  @@index([clientId])
  @@map("projects")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  clientId      String
  projectId     String
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  subtotal      Decimal       @default(0) @db.Decimal(14, 2)
  gstType       GstType       @default(CGST_SGST)
  gstRate       Decimal       @default(18) @db.Decimal(5, 2)
  cgstAmount    Decimal       @default(0) @db.Decimal(14, 2)
  sgstAmount    Decimal       @default(0) @db.Decimal(14, 2)
  igstAmount    Decimal       @default(0) @db.Decimal(14, 2)
  amount        Decimal       @db.Decimal(14, 2)
  placeOfSupply String?
  status        String        @default("pending")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@index([clientId])
  @@index([projectId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Decimal  @db.Decimal(14, 2)
  total       Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Quotation {
  id                   String                       @id @default(cuid())
  quotationNo          String                       @unique
  clientId             String
  projectId            String
  issueDate            DateTime                     @default(now())
  dueDate              DateTime?
  subtotal             Decimal                      @default(0) @db.Decimal(14, 2)
  executionFeeAmount   Decimal                      @default(0) @db.Decimal(14, 2)
  taxableAmount        Decimal                      @default(0) @db.Decimal(14, 2)
  gstType              GstType                      @default(CGST_SGST)
  gstRate              Decimal                      @default(18) @db.Decimal(5, 2)
  cgstAmount           Decimal                      @default(0) @db.Decimal(14, 2)
  sgstAmount           Decimal                      @default(0) @db.Decimal(14, 2)
  igstAmount           Decimal                      @default(0) @db.Decimal(14, 2)
  amount               Decimal                      @db.Decimal(14, 2)
  placeOfSupply        String?
  status               String                       @default("draft")
  notes                String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  executionFeePercent  Decimal                      @default(0) @db.Decimal(5, 2)
  items                QuotationItem[]
  vendorFurnitureItems VendorAccountFurnitureItem[]
  client               Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project              Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectId])
  @@map("quotations")
}

model QuotationItem {
  id                   String                       @id @default(cuid())
  quotationId          String
  description          String
  quantity             Float
  total                Decimal                      @db.Decimal(14, 2)
  createdAt            DateTime                     @default(now())
  area                 String
  category             String
  areaSqFt             Float?
  lengthCm             Float?
  rate                 Decimal?                     @db.Decimal(14, 2)
  vendorFurnitureItems VendorAccountFurnitureItem[]
  widthCm              Float?
  quotation            Quotation                    @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model VendorAccountFurnitureItem {
  id              String         @id @default(cuid())
  vendorAccountId String
  quotationId     String?
  quotationItemId String?
  area            String
  category        String
  description     String
  quantity        Float
  lengthCm        Float?
  widthCm         Float?
  areaSqFt        Float?
  quotationRate   Decimal?       @db.Decimal(14, 2)
  vendorRate      Decimal        @default(0) @db.Decimal(14, 2)
  vendorTotal     Decimal        @default(0) @db.Decimal(14, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  vendorAccount   VendorAccount  @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)
  quotation       Quotation?     @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  quotationItem   QuotationItem? @relation(fields: [quotationItemId], references: [id], onDelete: SetNull)

  @@unique([vendorAccountId, quotationItemId])
  @@index([quotationId])
  @@index([quotationItemId])
  @@map("vendor_account_furniture_items")
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Decimal  @db.Decimal(14, 2)
  method      String
  paymentDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  vendorId    String?
  projectId   String?
  amount      Decimal  @db.Decimal(14, 2)
  description String
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])

  @@index([clientId])
  @@index([projectId])
  @@index([vendorId])
  @@map("transactions")
}

model Purchase {
  id           String    @id @default(cuid())
  vendorId     String
  projectId    String
  purchaseNo   String    @unique
  items        String
  amount       Decimal   @db.Decimal(14, 2)
  status       String    @default("pending")
  purchaseDate DateTime  @default(now())
  dueDate      DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor       Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([vendorId])
  @@map("purchases")
}
